# PostgreSQL — application user (limited privileges on custom.* schema)
DATABASE_URL=postgresql://erp_app:CHANGE_ME@localhost:5432/odoo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=odoo
POSTGRES_USER=erp_app
POSTGRES_PASSWORD=CHANGE_ME

# PostgreSQL — superuser (only used for migrations / role bootstrap)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://localhost:6379

# Odoo
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_ADMIN_USER=admin
ODOO_ADMIN_PASSWORD=admin

# NestJS API
API_PORT=3001
API_HOST=0.0.0.0
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# Used by EncryptionService for pgcrypto field encryption (TIN, addresses).
# Generate with: openssl rand -hex 32
# Rotating this key requires re-encrypting every *_encrypted column — there is
# no automatic key-rotation routine yet (Phase 6 task).
ENCRYPTION_MASTER_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# 🇹🇭 Bank of Thailand FX reference rate API (Phase 4 multi-currency cron).
# IMPORTANT: the legacy apiportal.bot.or.th host was deprecated 2025-12-31.
# All new integrations must use portal.api.bot.or.th. Get an API key by
# registering at https://portal.api.bot.or.th and subscribing to the
# "Daily FX Rates" product.
BOT_FX_API_URL=https://portal.api.bot.or.th
BOT_FX_API_KEY=CHANGE_ME

# 🇹🇭 PromptPay refund channel — used in PP.30 (effective 2026-03-01).
# RD will refund VAT credits to this PromptPay ID linked to the merchant TIN.
# Format: 13-digit TIN OR mobile number in E.164 (+66...).
PROMPTPAY_REFUND_ID=

# AI (optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=master_key

# File Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
