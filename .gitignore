apps/mobile/package-lock.json
apps/mobile/vendor/
apps/mobile/ios/Pods/
apps/mobile/ios/build/
apps/mobile/ios/*.xcworkspace/xcuserdata/
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/app/build/

# Vitest / Test output
apps/*/test-results/
apps/*/coverage/
