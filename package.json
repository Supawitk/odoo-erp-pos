{
  "name": "odoo-erp-pos",
  "private": true,
  "version": "0.0.1",
  "description": "Full Odoo Community ERP/POS with React Native iPad + React Router v7 Dashboard",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @erp/db migrate",
    "db:generate": "pnpm --filter @erp/db generate",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.9.5",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
